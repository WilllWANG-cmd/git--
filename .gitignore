# 依赖（npm install 后生成，几百 MB，不进仓库）
node_modules/

# 打包输出（electron-builder 产物，不进仓库；.exe 用 GitHub Releases 发布）
dist/
out/
release/

# 日志
*.log
npm-debug.*
yarn-debug.*
yarn-error.*

# 系统文件
.DS_Store
Thumbs.db
desktop.ini

# 构建出的二进制（用 GitHub Releases 发布，不进 git）
*.exe
*.app
*.dmg
*.AppImage
*.snap
*.deb
*.rpm
